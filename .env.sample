REACT_APP_STAGE=demo
PORT=3101

#Update values and rename to .env.  For local development you may keep these values.
#Single base URL for all ChurchApps APIs (membership, attendance, content, giving, messaging, doing, reporting).
REACT_APP_API_BASE=https://api.staging.churchapps.org

REACT_APP_CONTENT_ROOT=https://content.staging.churchapps.org

#For localhost
#REACT_APP_API_BASE=http://localhost:8084
#REACT_APP_CONTENT_ROOT=http://localhost:3402

#Optional - UA-123456789-1
REACT_APP_GOOGLE_ANALYTICS=

#B1 Website URL
REACT_APP_B1_WEBSITE_URL=https://{subdomain}.staging.b1.church

#Chat mode: "standard" (Help Assistant), "bez" (Bez character), "superbee" (SuperBee), or omit to disable
#REACT_APP_CHAT_MODE=standard
